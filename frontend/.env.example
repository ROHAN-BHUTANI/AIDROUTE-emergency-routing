# AIDROUTE Frontend Environment Variables
# For local development: Copy to .env.local
# For Vercel: Set in Vercel dashboard (Project Settings > Environment Variables)

# ============================================================================
# Backend API URL
# ============================================================================
# Local development
NEXT_PUBLIC_API_URL=http://localhost:5000

# Production (set to your Render backend URL after deployment)
# Example: NEXT_PUBLIC_API_URL=https://aidroute-backend.onrender.com

