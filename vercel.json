{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/.next",
  "nodeVersion": "20.x",
  "framework": "nextjs",
  
  "env": {
    "NEXT_PUBLIC_API_URL": {
      "description": "Backend API URL (set in Vercel dashboard)",
      "required": true,
      "default": "http://localhost:5000"
    }
  },
  
  "envPrefix": "NEXT_PUBLIC_",
  
  "functions": {
    "frontend/.next/standalone/server.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  
  "headers": [
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    }
  ]
}
